# Compose overrides DATABASE_URL automatically to point to the postgres container.
# Keep this value for local fallback or manual runs.
DATABASE_URL="postgresql://autoparts_user:change_me_strong_password@db:5432/autoparts_pos?schema=public"

# JWT Configuration
JWT_ACCESS_SECRET="change-this-access-secret"
JWT_REFRESH_SECRET="change-this-refresh-secret"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Application
PORT=3000
NODE_ENV="production"

# CORS (must match your frontend URL exactly)
FRONTEND_URL="http://YOUR_SERVER_IP"

# Stock Alert Configuration
STOCK_CHECK_INTERVAL="*/5 * * * *"
STOCK_ALERT_COOLDOWN_HOURS=24

# Email Configuration (OVH)
SMTP_HOST=smtp.mail.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="contact@your-domain.tld"
SMTP_PASSWORD="your-ovh-mail-password"
EMAIL_FROM="Auto Parts POS <contact@your-domain.tld>"
ADMIN_EMAIL="contact@your-domain.tld"
