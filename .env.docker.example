POSTGRES_DB=autoparts_pos
POSTGRES_USER=autoparts_user
POSTGRES_PASSWORD=change_me_strong_password

# URL used by backend CORS (the browser origin of your frontend)
FRONTEND_URL=http://YOUR_SERVER_IP

# URL baked into frontend build for API calls.
# For non-SSL setup on a single VPS, this can be:
# VITE_API_URL=http://YOUR_SERVER_IP:3000
VITE_API_URL=http://YOUR_SERVER_IP:3000
